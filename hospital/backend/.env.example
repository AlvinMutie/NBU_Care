PORT=4000
NODE_ENV=development

# MySQL (XAMPP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nbu_nurse_assistant

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=12h

# CORS
FRONTEND_ORIGIN=http://localhost

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# Bootstrap admin user (created/updated on server start)
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_FULLNAME=NBU Administrator
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe12345

